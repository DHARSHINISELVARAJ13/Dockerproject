{
  "uid": "quickblog-ai-generation",
  "title": "QuickBlog AI Generation",
  "description": "Monitors request volume, latency percentiles, and failure behavior for the synchronous AI content generator.",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "tags": ["quickblog", "ai", "openai"],
  "time": { "from": "now-6h", "to": "now" },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Generation Health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "AI Request Rate",
      "description": "Throughput for the synchronous AI content generation path.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "rate(quickblog_ai_generation_requests_total[5m])",
          "legendFormat": "requests/sec",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "AI Failure Rate",
      "description": "Shows whether the generator is failing too often.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "100 * sum(rate(quickblog_ai_generation_requests_total{outcome=\"failure\"}[5m])) / sum(rate(quickblog_ai_generation_requests_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "AI Latency Percentiles",
      "description": "P50, P95, and P99 latency for the AI generation endpoint.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(quickblog_ai_generation_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(quickblog_ai_generation_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(quickblog_ai_generation_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    }
  ]
}