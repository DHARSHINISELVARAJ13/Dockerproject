{
  "uid": "quickblog-platform-overview",
  "title": "QuickBlog Platform Overview",
  "description": "Single-pane operational view of traffic, errors, latency percentiles, and route concentration.",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "tags": ["quickblog", "prometheus", "overview"],
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Traffic",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Request Throughput",
      "description": "Total backend request rate across all routes.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(quickblog_http_requests_total[5m]))",
          "legendFormat": "requests/sec",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "HTTP 5xx Error Rate",
      "description": "Percentage of requests that end in server errors.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "100 * sum(rate(quickblog_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(quickblog_http_requests_total[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Latency Percentiles",
      "description": "P50, P95, and P99 request latency across all backend routes.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(quickblog_http_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(quickblog_http_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(quickblog_http_request_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 5,
      "type": "row",
      "title": "Route Heatmap",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "id": 6,
      "type": "heatmap",
      "title": "Request Heatmap by Route",
      "description": "Highlights route concentration so the /api/blog/generate path stands out when traffic spikes.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "sum by (le, route) (rate(quickblog_http_request_duration_ms_bucket[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    }
  ]
}