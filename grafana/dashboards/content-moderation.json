{
  "uid": "quickblog-content-moderation",
  "title": "QuickBlog Content Moderation",
  "description": "Tracks backlog depth, approval latency, and moderation decision volume for blogs and comments.",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "tags": ["quickblog", "moderation"],
  "time": { "from": "now-6h", "to": "now" },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Backlog",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pending Queue Depth",
      "description": "Combined number of pending blog and comment reviews.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum(quickblog_moderation_queue_depth{outcome=\"pending\"})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Blog Moderation Decisions",
      "description": "Approval and rejection rates for blogs.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(quickblog_blog_moderation_actions_total[5m])) by (outcome)",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Comment Moderation Decisions",
      "description": "Approval and rejection rates for comments.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "sum(rate(quickblog_comment_moderation_actions_total[5m])) by (outcome)",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "row",
      "title": "Decision Latency",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Time from Submit to Decision",
      "description": "P95 moderation latency for blog and comment items.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(quickblog_moderation_resolution_duration_ms_bucket{content_category=\"blog\"}[5m])) by (le))",
          "legendFormat": "blog p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(quickblog_moderation_resolution_duration_ms_bucket{content_category=\"comment\"}[5m])) by (le))",
          "legendFormat": "comment p95",
          "refId": "B"
        }
      ]
    }
  ]
}